            <Sparkles className="w-6 h-6 text-amber-500" />
            <span className="text-2xl font-black text-white font-headline">العهد المكي</span>
          </motion.div>
          <h2 className="text-5xl md:text-7xl font-black text-white tracking-tighter mb-8">من الميلاد إلى الهجرة</h2>
