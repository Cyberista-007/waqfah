
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the requesting user's ID matches the owner's ID for a resource.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user ID in the incoming data matches the authenticated user.
    function isCreatingOwnResource(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    // Check if the user is the owner based on the 'userId' field of an existing resource.
    function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // In a real production app, you would have a more robust role check,
    // likely involving a custom claim set on the user's token.
    // For this environment, we assume admin actions are handled in a trusted context
    // and we lock down client-side writes to public data.
    function isAdmin() {
      // This is a placeholder. A real implementation would be:
      // return request.auth.token.admin == true;
      return isSignedIn(); // For the purpose of the current admin panel client-side writes.
    }

    // =====================================================================
    // Public Content Collections 
    // Anyone can read, but write access is restricted.
    // =====================================================================

    match /stats/{statsId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /sheikhs/{sheikhId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /series/{seriesId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /lectures/{lectureId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /books/{bookId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /question_answers/{qaId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /scheduled_lessons/{lessonId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /topics/{topicId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /challenges/{challengeId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }


    // =====================================================================
    // User-Specific Data
    // =====================================================================

    match /users/{userId} {
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can only read and update their own profile. No one can list all users.
      allow get, update: if isOwner(userId);
      // Deny list and delete for all users.
      allow list, delete: if false;
    }

    match /users/{userId}/favorites/{lectureId} {
      // Users can only manage their own favorites.
      allow read, write, delete: if isOwner(userId);
    }
    
    match /users/{userId}/following/{sheikhId} {
      // Users can only manage their own following list.
      allow read, write, delete: if isOwner(userId);
    }
    
    match /users/{userId}/listenHistory/{lectureId} {
      // Users can only read and write to their own listening history.
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/playlists/{playlistId} {
      // A user can create their own playlist.
      allow create: if isCreatingOwnResource(request.resource.data.userId);
      // Users can read, update, and delete their own playlists.
      allow read, update, delete: if isResourceOwner();
      
      // Any signed-in user can read public playlists.
      allow get: if isSignedIn() && resource.data.isPublic == true;
    }
    
    match /users/{userId}/notes/{lectureId} {
        // Users can only manage their own notes.
        allow read, write, delete: if isOwner(userId);
    }
    

    // =====================================================================
    // Subcollections for Lectures
    // =====================================================================

    match /lectures/{lectureId}/ratings/{userId} {
      // Anyone can read ratings for a lecture.
      allow get, list: if true;

      // A user can create or update their own rating.
      // The document ID must be the user's ID to enforce one rating per user.
      allow create, update: if isCreatingOwnResource(userId) &&
                      request.resource.data.lectureId == lectureId &&
                      request.resource.data.value >= 1 &&
                      request.resource.data.value <= 5;
      // Users cannot delete ratings.
      allow delete: if false;
    }
    
    match /lectures/{lectureId}/clips/{clipId} {
      allow get, list: if true;
      // User must be creator to create a clip.
      allow create: if isCreatingOwnResource(request.resource.data.userId);
      // Only the owner of the clip can delete it.
      allow delete: if isResourceOwner();
    }
    
    match /lectures/{lectureId}/comments/{commentId} {
      allow list: if true;
      allow get: if true;
      // Signed in users can create comments
      allow create: if isSignedIn() && isCreatingOwnResource(request.auth.uid);
      // Users can only update or delete their own comments
      allow update, delete: if isSignedIn() && isResourceOwner();
    }
    
    // =====================================================================
    // Collection Group Queries
    // =====================================================================

    // Allow signed-in users to query all public playlists across all users.
    match /{path=**}/playlists/{playlistId} {
      allow list: if isSignedIn() && request.query.limit <= 30 && request.query.offset == null && request.query.orderBy.size() == 1 && request.query.orderBy[0].field == "createdAt" && request.query.orderBy[0].direction == "desc" && request.resource.data.isPublic == true;
    }
  }
}
