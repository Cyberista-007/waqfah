rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'admin';
    }

    function isCreatingOwnResource(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // =====================================================================
    // Public Content Collections
    // =====================================================================

    match /sheikhs/{sheikhId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /series/{seriesId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /lectures/{lectureId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /question_answers/{qaId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /scheduled_lessons/{lessonId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /topics/{topicId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /challenges/{challengeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }


    // =====================================================================
    // User-Specific Data
    // =====================================================================

    match /users/{userId} {
      // Admins can read and update any user's role.
      // Users can only read and update their own profile (but not their role).
      allow get: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && !("role" in request.resource.data)) || 
                       (isAdmin() && !("role" in resource.data) && "role" in request.resource.data);
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Only admins can list all users.
      allow list: if isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    match /users/{userId}/favorites/{lectureId} {
      // Users can only manage their own favorites.
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/listenHistory/{lectureId} {
      // Users can only read and write to their own listening history.
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/playlists/{playlistId} {
      // Users can read, write, and delete their own playlists.
      allow read, write: if isOwner(userId);
      
      // Other signed-in users can read public playlists.
      allow get: if isSignedIn() && resource.data.isPublic == true;
    }
    

    // =====================================================================
    // Subcollections for Lectures
    // =====================================================================

    match /lectures/{lectureId}/ratings/{userId} {
      // Anyone can read ratings for a lecture.
      allow get, list: if true;

      // A user can create or update their own rating.
      allow write: if isCreatingOwnResource(userId) &&
                      request.resource.data.lectureId == lectureId &&
                      request.resource.data.value >= 1 &&
                      request.resource.data.value <= 5;
    }
    
    match /lectures/{lectureId}/clips/{clipId} {
      allow get, list: if true;
      allow create: if isCreatingOwnResource(request.resource.data.userId);
      allow delete: if isResourceOwner();
    }
  }
}
