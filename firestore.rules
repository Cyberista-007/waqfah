
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isBanned() {
      // ban_expires is a custom claim set in seconds since epoch.
      // request.time is a Timestamp object.
      return request.auth.token.ban_expires != null && request.auth.token.ban_expires > request.time.toMillis() / 1000;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCreatingOwnResource(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Check if the user has the 'admin' role in their user profile document.
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =====================================================================
    // Public Content Collections 
    // Anyone can read, but write access is restricted.
    // =====================================================================

    match /stats/{statsId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /programs/{programId} {
      allow get, list: if true;
      // Allow admins to do any write.
      // Allow any signed-in user to update only the followerCount.
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']);
    }

    match /channels/{channelId} {
      allow get, list: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']);
    }
    
    match /series/{seriesId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /lectures/{lectureId} {
      allow get, list: if true;
      // Admins can perform any write operation.
      // This also implicitly allows batched deletes by admins.
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /question_answers/{qaId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }

    match /scheduled_lessons/{lessonId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /topics/{topicId} {
      allow get, list: if true;
      allow write: if isAdmin(); // Only admins can modify.
    }
    
    match /challenges/{challengeId} {
      allow get, list: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount']);
    }

    match /settings/{settingsId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /donations/{donationId} {
      allow get, list: if true; // Allow public reading of donations for the wall
      allow write: if isAdmin(); // Only admins can add/edit/delete donations for now
    }

    // =====================================================================
    // User-Specific Data
    // =====================================================================

    match /users/{userId} {
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Anyone can read a user's public profile data
      allow get: if true;
      // Users can only update their own profile. Admins can update any profile.
      allow update: if isOwner(userId) || isAdmin();
      // Admins can list all users.
      allow list: if isAdmin();
      // A user can delete their own account.
      allow delete: if isOwner(userId);

       match /user_challenges/{challengeId} {
        allow read, write, delete: if isOwner(userId);
      }

      match /accountability/{entryId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    match /users/{userId}/favorites/{lectureId} {
      // Users can only manage their own favorites.
      allow read, write, delete: if isOwner(userId);
    }
    
    match /users/{userId}/following/{programId} {
      // Users can only manage their own following list.
      allow read, write, delete: if isOwner(userId);
    }
    
    match /users/{userId}/listenHistory/{lectureId} {
      // Users can only read and write to their own listening history.
      allow read, write, delete: if isOwner(userId);
    }

    match /users/{userId}/playlists/{playlistId} {
      // A user can create their own playlist.
      allow create: if isCreatingOwnResource(request.resource.data.userId);
      
      // A user can list their own playlists.
      allow list: if isOwner(userId);

      // Users can get, update, and delete their own playlists.
      allow get, update, delete: if isResourceOwner();
      
      // Allow ANYONE to get a public playlist.
      allow get: if resource.data.isPublic == true;
    }
    
    match /users/{userId}/notes/{lectureId} {
        // Users can only manage their own notes.
        allow read, write, delete: if isOwner(userId);
    }
    

    // =====================================================================
    // Subcollections for Lectures
    // =====================================================================

    match /lectures/{lectureId}/ratings/{userId} {
      // Anyone can read ratings for a lecture.
      allow get, list: if true;

      // A user can create or update their own rating.
      // The document ID must be the user's ID to enforce one rating per user.
      allow create, update: if isCreatingOwnResource(userId) &&
                      request.resource.data.lectureId == lectureId &&
                      request.resource.data.value >= 1 &&
                      request.resource.data.value <= 5;
      // Users cannot delete ratings.
      allow delete: if false;
    }
    
    match /lectures/{lectureId}/clips/{clipId} {
      allow get, list: if true;
      // User must be creator to create a clip.
      allow create: if isCreatingOwnResource(request.resource.data.userId);
      // Only the owner of the clip can delete it.
      allow delete: if isResourceOwner();
    }
    
    match /lectures/{lectureId}/comments/{commentId} {
      allow list: if true;
      allow get: if true;
      // Signed in users can create comments, if they are not banned
      allow create: if isSignedIn() && isCreatingOwnResource(request.auth.uid) && !isBanned();
      // Users can only update or delete their own comments, Admins can delete any.
      allow update, delete: if isSignedIn() && (isResourceOwner() || isAdmin());
    }
    
    // =====================================================================
    // Collection Group Queries
    // =====================================================================

    // This rule allows the client to query the 'playlists' collection group.
    // It's secured because the client query always includes `where('isPublic', '==', true)`
    // and the `get` rule for individual playlists (above) checks `resource.data.isPublic == true`.
    // This ensures only public playlists are returned by the query.
    match /{path=**}/playlists/{playlistId} {
      allow list: if request.query.limit <= 30;
    }

    match /{path=**}/clips/{clipId} {
      // Allow a user to query for their own clips.
      // The client query must include `where('userId', '==', request.auth.uid)`.
      // NOTE: Firestore rules cannot enforce 'where' clauses on collection group queries.
      // This rule is permissive and relies on the client to correctly filter.
      allow list: if isSignedIn();
    }
    
    match /{path=**}/notes/{lectureId} {
      // Allow a user to query for their own notes.
      // The profile page uses a direct collection query which is more secure.
      // This rule is a fallback but relies on client-side filtering.
      allow list: if isSignedIn();
    }
  }
}
