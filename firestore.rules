
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user ID in the incoming data matches the authenticated user.
    function isCreatingOwnResource(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    // Check if the user is the owner based on the 'userId' field of an existing resource.
    function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // =====================================================================
    // Public Content Collections (series, lectures, books, etc.)
    // Anyone can read, but only signed-in users (admins) can write.
    // In a real app, 'isSignedIn()' for write should be replaced with an admin check.
    // =====================================================================

    match /series/{seriesId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    match /lectures/{lectureId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Admin-only in production
    }

    match /books/{bookId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Admin-only in production
    }
    
    match /question_answers/{qaId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Admin-only in production
    }

    match /scheduled_lessons/{lessonId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Admin-only in production
    }


    // =====================================================================
    // User-Specific Data
    // =====================================================================

    match /users/{userId} {
      // Users can only read and update their own profile. No one can list all users.
      allow get, update: if isOwner(userId);
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      allow list, delete: if false;
    }

    match /users/{userId}/favorites/{lectureId} {
      // Users can only manage their own favorites.
      allow read, write: if isOwner(userId);
    }
    

    // =====================================================================
    // Subcollections for Lectures
    // =====================================================================

    match /lectures/{lectureId}/ratings/{userId} {
      // Anyone can read ratings for a lecture.
      allow get, list: if true;

      // A user can create or update their own rating.
      // The document ID must be the user's ID to enforce one rating per user.
      allow write: if isCreatingOwnResource(userId) &&
                      request.resource.data.lectureId == lectureId &&
                      request.resource.data.value >= 1 &&
                      request.resource.data.value <= 5;
    }

    match /lectures/{lectureId}/comments/{commentId} {
      // Anyone can read 'approved' comments.
      allow get: if resource.data.status == 'approved';
      
      // Allow listing comments but only if filtered by 'approved' status.
      allow list: if request.query.get('where.status') == 'approved';
      
      // A signed-in user can create a comment, which must be 'pending'.
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.status == 'pending';
      
      // An 'admin' (any signed-in user for now) can update only the status.
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // The original author can delete their comment if it's 'pending' or 'rejected'.
      allow delete: if isResourceOwner() && (resource.data.status == 'pending' || resource.data.status == 'rejected');
    }

    // =====================================================================
    // Admin-Only Collection Group Queries
    // =====================================================================
    
    // Allows admins to query the 'comments' collection group across all lectures
    // to see pending/rejected comments.
    match /{path=**}/comments/{commentId} {
       allow list: if isSignedIn(); // Should be admin-only
    }
  }
}
