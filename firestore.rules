
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isBanned() {
      return request.auth.token.ban_expires != null && request.auth.token.ban_expires > request.time.toMillis() / 1000;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isCreatingOwnResource(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =====================================================================
    // Public Content Collections 
    // =====================================================================

    match /inspiration/{id} { allow read, get, list: if true; allow write: if isAdmin(); }
    match /shubuhat/{id} { allow read, get, list: if true; allow write: if isAdmin(); }
    match /stats/{id} { allow read: if true; allow write: if isAdmin(); }
    match /books/{id} { allow read: if true; allow write: if isAdmin(); }
    match /question_answers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /muhlikat/{id} { allow read: if true; allow write: if isAdmin(); }
    match /scheduled_lessons/{id} { allow read: if true; allow write: if isAdmin(); }
    match /topics/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /donations/{id} { allow read: if true; allow write: if isAdmin(); }
    match /destructive_sins/{id} { allow read: if true; allow write: if isAdmin(); }
    match /gamification_badges/{id} { allow read: if true; allow write: if isAdmin(); }
    match /series/{id} { allow read: if true; allow write: if isAdmin(); }

    // Palestine solidarity pledges — written ONLY by server-side Admin SDK.
    // Client rules are restrictive because the API route uses firebase-admin
    // which bypasses these rules. This is intentional security-in-depth.
    match /palestine_pledges/{fingerprintId} {
      allow read: if false;   // Fingerprints are never exposed to clients
      allow write: if false;  // Only server-side Admin SDK can write
    }

    match /programs/{programId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']);
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount']);
    }

    match /curriculums/{curriculumId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']);
    }

    match /lectures/{lectureId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['suggestionCount']);

      match /suggestions/{userId} {
        allow read, create, delete: if isOwner(userId);
      }
      match /ratings/{userId} {
        allow read: if true;
        allow create, update: if isCreatingOwnResource(userId) && request.resource.data.value >= 1 && request.resource.data.value <= 5;
      }
      match /clips/{clipId} {
        allow read: if true;
        allow create: if isCreatingOwnResource(request.resource.data.userId);
        allow delete: if isResourceOwner();
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isCreatingOwnResource(request.auth.uid) && !isBanned();
        allow update, delete: if isSignedIn() && (isResourceOwner() || isAdmin());
      }
    }

    // =====================================================================
    // User-Specific Data
    // =====================================================================

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow get: if true;
      allow update, delete: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn();

      // Notifications access
      match /notifications/{id} {
        allow read, write: if isOwner(userId);
      }

      // State access
      match /state/{document} {
        allow read, write: if isOwner(userId);
      }
      
      match /favorites/{document} {
        allow read, write: if isOwner(userId);
      }

      // Playlists
      match /playlists/{playlistId} {
        allow create: if isCreatingOwnResource(request.resource.data.userId) || isOwner(userId);
        allow read, update, delete: if isOwner(userId) || (resource != null && resource.data.isPublic == true);
      }

      // Recursive Wildcard for other private data
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // =====================================================================
    // Collection Group Queries
    // =====================================================================

    match /{path=**}/playlists/{playlistId} {
      allow list, get: if (resource == null) || (resource.data.isPublic == true) || (isSignedIn() && request.auth.uid in path);
    }

    match /{path=**}/clips/{clipId} {
      allow list, get: if isSignedIn();
    }
    
    match /{path=**}/notes/{lectureId} {
      allow list, get: if isSignedIn();
    }
  }
}
