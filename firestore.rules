/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a combination of public read access for general content and authenticated-user write access for content management. User-specific data remains protected by ownership checks.
 *
 * Data Structure:
 * - `/series/{seriesId}`: Series data.
 * - `/lectures/{lectureId}`: Lecture data.
 * - `/books/{bookId}`: Book data.
 * - `/question_answers/{questionAnswerId}`: Question and answer data.
 * - `/scheduled_lessons/{scheduledLessonId}`: Scheduled lesson data.
 * - `/users/{userId}`: User profile data.
 * - `/lectures/{lectureId}/comments/{commentId}`: Comments on lectures.
 *
 * Key Security Decisions:
 * - Public read access is granted to all content to allow anonymous browsing.
 * - Write access (create, update, delete) to content collections (series, lectures, etc.) is restricted to authenticated users. This is a simple authorization model where any logged-in user is treated as an admin/editor. For more granular control, custom claims (e.g., `request.auth.token.isAdmin`) should be implemented.
 * - User data and subcollections are strictly protected by ownership checks (`isOwner`).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Public read, authenticated write.
     * @path /series/{seriesId}
     * @allow (get, list): Anyone can read series data.
     * @allow (create, update, delete): Any signed-in user can manage series data.
     */
    match /series/{seriesId} {
      allow get: if true;
      allow list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Public read, authenticated write.
     * @path /lectures/{lectureId}
     * @allow (get, list): Anyone can read lecture data.
     * @allow (create, update, delete): Any signed-in user can manage lecture data.
     */
    match /lectures/{lectureId} {
      allow get: if true;
      allow list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Public read, authenticated write.
     * @path /books/{bookId}
     * @allow (get, list): Anyone can read book data.
     * @allow (create, update, delete): Any signed-in user can manage book data.
     */
    match /books/{bookId} {
      allow get: if true;
      allow list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Public read, authenticated write.
     * @path /question_answers/{questionAnswerId}
     * @allow (get, list): Anyone can read Q&A data.
     * @allow (create, update, delete): Any signed-in user can manage Q&A data.
     */
    match /question_answers/{questionAnswerId} {
      allow get: if true;
      allow list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Public read, authenticated write.
     * @path /scheduled_lessons/{scheduledLessonId}
     * @allow (get, list): Anyone can read scheduled lesson data.
     * @allow (create, update, delete): Any signed-in user can manage lesson data.
     */
    match /scheduled_lessons/{scheduledLessonId} {
      allow get: if true;
      allow list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Allows read/write access to a user's own profile data.
     * @path /users/{userId}
     * @allow (create, get, update, delete): User can manage their own profile.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Deny listing all users
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    /**
     * @description Public read, authenticated user can create. Owner can update/delete.
     * @path /lectures/{lectureId}/comments/{commentId}
     * @allow (get, list): Anyone can read comments.
     * @allow (create): Authenticated user can create a comment if they own it.
     * @allow (update, delete): The user who created the comment can update or delete it.
     */
    match /lectures/{lectureId}/comments/{commentId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isResourceOwner();
      allow delete: if isSignedIn() && isResourceOwner();
    }
  }

  // --- Helper Functions ---

  /**
   * Checks if the current request is from an authenticated user.
   */
  function isSignedIn() {
    return request.auth != null;
  }

  /**
   * Checks if the requesting user's UID matches the given userId.
   * Used for path-based ownership checks.
   */
  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  /**
   * Checks if the requesting user's UID matches the 'userId' field in the document being written/updated.
   * Used for field-based ownership checks.
   */
  function isResourceOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
  }
}
