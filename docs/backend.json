{
  "entities": {
    "Series": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Series",
      "type": "object",
      "description": "Represents a series of lectures.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageId": { "type": "string" },
        "lectureCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "description", "imageId", "createdAt"]
    },
    "Lecture": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lecture",
      "type": "object",
      "description": "Represents a single lecture.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "seriesId": { "type": "string" },
        "seriesSlug": { "type": "string" },
        "seriesTitle": { "type": "string" },
        "audioSrc": { "type": "string", "format": "uri" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "pdfUrl": { "type": "string", "format": "uri" },
        "imageId": { "type": "string" },
        "duration": { "type": "number" },
        "transcript": { "type": "array" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "seriesId", "seriesSlug", "seriesTitle", "audioSrc", "imageId", "createdAt"]
    },
    "Book": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Book",
      "type": "object",
      "description": "Represents a book or publication.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "pdfUrl": { "type": "string", "format": "uri" },
        "imageId": { "type": "string" }
      },
      "required": ["slug", "title", "pdfUrl", "imageId"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "minutesListened": { "type": "number" },
        "lecturesCompleted": { "type": "number" },
        "seriesCompleted": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "createdAt"]
    },
    "Comment": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Comment",
        "type": "object",
        "properties": {
            "lectureId": { "type": "string" },
            "lectureSlug": { "type": "string" },
            "lectureTitle": { "type": "string" },
            "userId": { "type": "string" },
            "userName": { "type": "string" },
            "userImage": { "type": "string", "format": "uri" },
            "text": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["lectureId", "userId", "userName", "text", "status", "createdAt"]
    },
    "Favorite": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Favorite",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "addedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "addedAt"]
    },
    "Rating": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Rating",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "value": { "type": "number", "minimum": 1, "maximum": 5 },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "value", "createdAt"]
    },
    "ListenHistory": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "ListenHistory",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "position": { "type": "number" },
            "duration": { "type": "number" },
            "lastListened": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "position", "duration", "lastListened"]
    },
    "Playlist": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Playlist",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "lectureIds": { "type": "array", "items": { "type": "string" } },
            "isPublic": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "name", "lectureIds", "isPublic", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/series/{seriesId}",
        "definition": { "schema": { "$ref": "#/entities/Series" } }
      },
      {
        "path": "/lectures/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/Lecture" } }
      },
      {
        "path": "/books/{bookId}",
        "definition": { "schema": { "$ref": "#/entities/Book" } }
      },
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/entities/UserProfile" } }
      },
      {
        "path": "/users/{userId}/favorites/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/Favorite" } }
      },
      {
        "path": "/users/{userId}/listenHistory/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/ListenHistory" } }
      },
      {
        "path": "/users/{userId}/playlists/{playlistId}",
        "definition": { "schema": { "$ref": "#/entities/Playlist" } }
      },
      {
        "path": "/lectures/{lectureId}/comments/{commentId}",
        "definition": { "schema": { "$ref": "#/entities/Comment" } }
      },
      {
        "path": "/lectures/{lectureId}/ratings/{userId}",
        "definition": { "schema": { "$ref": "#/entities/Rating" } }
      }
    ]
  }
}

    