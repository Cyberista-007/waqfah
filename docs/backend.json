{
  "entities": {
    "Sheikh": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sheikh",
      "type": "object",
      "description": "Represents a Sheikh or author on the platform.",
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "imageId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "name", "bio", "imageId", "createdAt"]
    },
    "Series": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Series",
      "type": "object",
      "description": "Represents a series of lectures by a specific sheikh.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageId": { "type": "string" },
        "lectureCount": { "type": "number" },
        "sheikhId": { "type": "string" },
        "sheikhName": { "type": "string" },
        "sheikhSlug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "description", "imageId", "sheikhId", "sheikhName", "sheikhSlug", "createdAt"]
    },
    "Lecture": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lecture",
      "type": "object",
      "description": "Represents a single lecture by a specific sheikh.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "sheikhId": { "type": "string" },
        "sheikhName": { "type": "string" },
        "sheikhSlug": { "type": "string" },
        "seriesId": { "type": "string" },
        "seriesSlug": { "type": "string" },
        "seriesTitle": { "type": "string" },
        "audioSrc": { "type": "string", "format": "uri" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "pdfUrl": { "type": "string", "format": "uri" },
        "imageId": { "type": "string" },
        "duration": { "type": "number" },
        "transcript": { "type": "array" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "sheikhId", "sheikhName", "sheikhSlug", "seriesId", "seriesSlug", "seriesTitle", "audioSrc", "imageId", "createdAt"]
    },
    "Book": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Book",
      "type": "object",
      "description": "Represents a book or publication by a specific sheikh.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "pdfUrl": { "type": "string", "format": "uri" },
        "imageId": { "type": "string" },
        "sheikhId": { "type": "string" },
        "sheikhName": { "type": "string" },
        "sheikhSlug": { "type": "string" }
      },
      "required": ["slug", "title", "pdfUrl", "imageId", "sheikhId", "sheikhName", "sheikhSlug"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "bio": { "type": "string" },
        "minutesListened": { "type": "number" },
        "lecturesCompleted": { "type": "number" },
        "seriesCompleted": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "name", "createdAt"]
    },
    "Favorite": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Favorite",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "addedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "addedAt"]
    },
    "Rating": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Rating",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "value": { "type": "number", "minimum": 1, "maximum": 5 },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "value", "createdAt"]
    },
    "ListenHistory": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "ListenHistory",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "lectureId": { "type": "string" },
            "position": { "type": "number" },
            "duration": { "type": "number" },
            "lastListened": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "lectureId", "position", "duration", "lastListened"]
    },
    "Playlist": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Playlist",
        "type": "object",
        "properties": {
            "userId": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "lectureIds": { "type": "array", "items": { "type": "string" } },
            "isPublic": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "name", "lectureIds", "isPublic", "createdAt"]
    },
    "Topic": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Topic",
      "description": "Represents a subject or category grouping various content.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "imageId": { "type": "string" },
        "lectureIds": { "type": "array", "items": { "type": "string" } },
        "seriesIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "slug", "description"]
    },
    "Challenge": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Challenge",
      "description": "A listening challenge for users to complete.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "lectureIds": { "type": "array", "items": { "type": "string" } },
        "seriesId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["title", "description", "startDate", "endDate", "isActive"]
    },
    "LectureClip": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LectureClip",
      "description": "A short, shareable clip from a lecture.",
      "type": "object",
      "properties": {
        "lectureId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["lectureId", "userId", "title", "startTime", "endTime", "createdAt"]
    },
    "ScheduleItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ScheduleItem",
      "description": "An item in the lesson schedule.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "isLive": { "type": "boolean" }
      },
      "required": ["title", "dateTime", "isLive"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/sheikhs/{sheikhId}",
        "definition": { "schema": { "$ref": "#/entities/Sheikh" } }
      },
      {
        "path": "/series/{seriesId}",
        "definition": { "schema": { "$ref": "#/entities/Series" } }
      },
      {
        "path": "/lectures/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/Lecture" } }
      },
      {
        "path": "/books/{bookId}",
        "definition": { "schema": { "$ref": "#/entities/Book" } }
      },
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/entities/UserProfile" } }
      },
      {
        "path": "/users/{userId}/favorites/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/Favorite" } }
      },
      {
        "path": "/users/{userId}/listenHistory/{lectureId}",
        "definition": { "schema": { "$ref": "#/entities/ListenHistory" } }
      },
      {
        "path": "/users/{userId}/playlists/{playlistId}",
        "definition": { "schema": { "$ref": "#/entities/Playlist" } }
      },
      {
        "path": "/lectures/{lectureId}/ratings/{userId}",
        "definition": { "schema": { "$ref": "#/entities/Rating" } }
      },
      {
        "path": "/topics/{topicId}",
        "definition": { "schema": { "$ref": "#/entities/Topic" } }
      },
      {
        "path": "/challenges/{challengeId}",
        "definition": { "schema": { "$ref": "#/entities/Challenge" } }
      },
      {
        "path": "/lectures/{lectureId}/clips/{clipId}",
        "definition": { "schema": { "$ref": "#/entities/LectureClip" } }
      },
      {
        "path": "/scheduled_lessons/{lessonId}",
        "definition": { "schema": { "$ref": "#/entities/ScheduleItem" } }
      }
    ]
  }
}
